<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPickTeam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/pick_team"
        app:navigationIcon="@drawable/baseline_arrow_circle_left_24"
        app:menu="@menu/menu_pick_team"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Stats row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:dividerPadding="8dp"
            android:weightSum="4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txtBudgetRemaining"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="@string/budget_100_0m"
                    android:textAlignment="center"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txtTotalPoints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="@string/_0_pts"
                    android:textAlignment="center"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/txtFreeTransfers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="@string/transfers"
                    android:textAlignment="center"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/txtDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="@string/deadline"
                    android:textAlignment="center"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Pitch board -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/pitchBoard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/statsRow"
            app:layout_constraintBottom_toTopOf="@id/benchBanner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="16:9">

        <!-- Pitch background -->
            <ImageView
                android:id="@+id/imgPitch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/pitch1_inset"
                tools:ignore="ContentDescription" />

            <!-- Overlay: you’ll place your 11 slot views here (ConstraintLayout is easiest) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/pitchOverlay"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:padding="12dp"
                android:elevation="20dp"
                android:clickable="false"
                android:focusable="false"
                android:background="#33FF0000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />>

                <!-- Vertical guidelines to split the pitch into 4 columns -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gLineGK"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.10" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gLineDEF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.33" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gLineMID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.62" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gLineST"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="1.0" />


                <!-- Example slot (GK). You’ll create 11 of these -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotGK"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@android:color/holo_red_light"
                    app:layout_constraintStart_toStartOf="@id/gLineGK"
                    app:layout_constraintEnd_toEndOf="@id/gLineGK"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <!-- DEFENCE 4 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotLB"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:layout_constraintStart_toStartOf="@id/gLineDEF"
                    app:layout_constraintEnd_toEndOf="@id/gLineDEF"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/slotLCB"
                    app:layout_constraintVertical_chainStyle="spread">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotLCB"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:layout_constraintStart_toStartOf="@id/gLineDEF"
                    app:layout_constraintEnd_toEndOf="@id/gLineDEF"
                    app:layout_constraintTop_toBottomOf="@id/slotLB"
                    app:layout_constraintBottom_toTopOf="@id/slotRCB">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotRCB"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:layout_constraintStart_toStartOf="@id/gLineDEF"
                    app:layout_constraintEnd_toEndOf="@id/gLineDEF"
                    app:layout_constraintTop_toBottomOf="@id/slotLCB"
                    app:layout_constraintBottom_toTopOf="@id/slotRB">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotRB"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:layout_constraintStart_toStartOf="@id/gLineDEF"
                    app:layout_constraintEnd_toEndOf="@id/gLineDEF"
                    app:layout_constraintTop_toBottomOf="@id/slotRCB"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <!-- MIDFIELD 5 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotLM"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@android:color/holo_red_light"
                    app:layout_constraintStart_toStartOf="@id/gLineMID"
                    app:layout_constraintEnd_toEndOf="@id/gLineMID"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/slotLCM"
                    app:layout_constraintVertical_chainStyle="spread">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotLCM"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:layout_constraintStart_toStartOf="@id/gLineMID"
                    app:layout_constraintEnd_toEndOf="@id/gLineMID"
                    app:layout_constraintTop_toBottomOf="@id/slotLM"
                    app:layout_constraintBottom_toTopOf="@id/slotCM">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotCM"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:layout_constraintStart_toStartOf="@id/gLineMID"
                    app:layout_constraintEnd_toEndOf="@id/gLineMID"
                    app:layout_constraintTop_toBottomOf="@id/slotLCM"
                    app:layout_constraintBottom_toTopOf="@id/slotRCM">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotRCM"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:layout_constraintStart_toStartOf="@id/gLineMID"
                    app:layout_constraintEnd_toEndOf="@id/gLineMID"
                    app:layout_constraintTop_toBottomOf="@id/slotCM"
                    app:layout_constraintBottom_toTopOf="@id/slotRM">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotRM"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:layout_constraintStart_toStartOf="@id/gLineMID"
                    app:layout_constraintEnd_toEndOf="@id/gLineMID"
                    app:layout_constraintTop_toBottomOf="@id/slotRCM"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <!-- STRIKER -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/slotST"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="18dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@drawable/outline_add_circle_24"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Bench banner (bottom) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/benchBanner"
            android:layout_width="0dp"
            android:layout_height="90dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBench"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:clipToPadding="false"/>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
